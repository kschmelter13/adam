ANTHROPIC_API_KEY=sk-ant-...

# Personal Vercel access token. Create at: https://vercel.com/account/tokens
# Named ADAM_* on purpose — VERCEL_TOKEN triggers Vercel's deploy form to
# show a misleading "Populated by System" placeholder that doesn't actually
# get populated. ADAM_VERCEL_TOKEN forces an empty input the user must fill.
ADAM_VERCEL_TOKEN=

# Optional: deploy into a specific team. Leave blank for personal scope.
ADAM_VERCEL_TEAM_ID=

# Personal GitHub access token. Create at: https://github.com/settings/tokens
# Classic: `repo` scope. Fine-grained: Contents RW + Administration RW + Metadata read.
# Adam uses this to create a repo per agent it builds and push code into it.
GITHUB_TOKEN=
